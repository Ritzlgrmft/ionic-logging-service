{
  "name": "ionic-logging",
  "version": "21.0.0",
  "description": "Components for Ionic logging",
  "author": {
    "name": "Markus Wagner",
    "email": "markus.wagner02@web.de"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ritzlgrmft/ionic-logging-service.git"
  },
  "license": "MIT",
  "private": false,
  "keywords": [
    "ionic",
    "angular",
    "mobile",
    "logging",
    "log4javascript"
  ],
  "scripts": {
    "build": "npm run build-service && npm run build-viewer && npm run build-viewer-app",
    "build-service": "ng build ionic-logging-service --configuration production",
    "build-viewer": "ng build ionic-logging-viewer --configuration production",
    "build-viewer-app": "ng build ionic-logging-viewer-app --configuration production",
    "test": "npm run test-service && npm run test-viewer && ng lint && npm run e2e",
    "test-service": "npm run test-coverage-service && npm run test-compodoc-service",
    "test-viewer": "npm run test-coverage-viewer && npm run test-compodoc-viewer",
    "test-coverage-service": "ng test ionic-logging-service --watch false --browsers ChromeHeadless",
    "test-coverage-viewer": "ng test ionic-logging-viewer --watch false --browsers ChromeHeadless",
    "test-compodoc-service": "cd projects/ionic-logging-service && compodoc --coverageTest 100 && cd ../..",
    "test-compodoc-viewer": "cd projects/ionic-logging-viewer && compodoc --coverageTest 100 && cd ../..",
    "test-watch-service": "ng test ionic-logging-service --code-coverage",
    "test-watch-viewer": "ng test ionic-logging-viewer --code-coverage",
    "lint": "ng lint",
    "e2e": "npm run cypress:run",
    "compodoc": "npm run compodoc-service && npm run compodoc-viewer",
    "compodoc-service": "cd projects/ionic-logging-service && compodoc && cd ../..",
    "compodoc-viewer": "cd projects/ionic-logging-viewer && compodoc && cd ../..",
    "cypress:open": "ng run ionic-logging-viewer-app:cypress-open",
    "cypress:run": "ng run ionic-logging-viewer-app:cypress-run",
    "serve-viewer-app": "ionic serve --project ionic-logging-viewer-app"
  },
  "dependencies": {
    "@angular/common": ">=21.0.0",
    "@angular/compiler": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0",
    "@angular/platform-browser": ">=21.0.0",
    "@angular/platform-browser-dynamic": ">=21.0.0",
    "@angular/router": ">=21.0.0",
    "@ionic/angular": ">=8.0.0",
    "ionicons": ">=8.0.0",
    "log4javascript": "^1.4.16",
    "rxjs": "^7.5.0",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2200.0",
    "@angular-devkit/schematics": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@compodoc/compodoc": "1.2.1",
    "@cypress/schematic": "^5.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@ionic/angular": "^8.8.9",
    "@types/jasmine": "~6.0.0",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "angular-eslint": "^22.0.0",
    "cypress": "15.17.0",
    "eslint": "^10.4.1",
    "eslint-plugin-jsdoc": "63.0.2",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "fsevents": "2.3.3",
    "ionicons": "8.0.13",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "^5.13.0",
    "jasmine-reporters": "2.5.2",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "karma-junit-reporter": "2.0.1",
    "ng-packagr": "^22.0.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}